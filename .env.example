# App configuration
VITE_AWS_REGION=eu-west-2
VITE_TABLE_NAME=data-broker-remover-users
VITE_COMPANIES=BrokerName1,email1@domain.com:BrokerName2,email2@domain.com

# Server-side email settings
SES_FROM_EMAIL=noreply@example.com
SES_REQUESTS_EMAIL=requests@example.com

# Optional local development credentials only
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-2

# Optional assistant foundation, disabled by default
ENABLE_AI_ASSISTANT=false
OPENAI_MODEL=gpt-5.4
ASSISTANT_SCOPE_MODE=strict
# OPENAI_API_KEY=sk-...
